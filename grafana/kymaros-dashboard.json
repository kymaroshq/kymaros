{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Average Restore Score",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "avg(kymaros_score)",
          "legendFormat": "Average Score",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 60, "color": "orange" },
              { "value": 80, "color": "green" }
            ]
          },
          "unit": "none"
        }
      }
    },
    {
      "title": "Tests Executed",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(kymaros_tests_total)",
          "legendFormat": "Total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "value": 0, "color": "blue" }
            ]
          }
        }
      }
    },
    {
      "title": "Failed Tests (24h)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(increase(kymaros_tests_total{result=\"fail\"}[24h]))",
          "legendFormat": "Failures",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 1, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "title": "Avg RTO",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "avg(kymaros_rto_seconds)",
          "legendFormat": "Avg RTO",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 600, "color": "orange" },
              { "value": 1800, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "title": "Score per RestoreTest",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "kymaros_score",
          "legendFormat": "{{ test }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 60, "color": "orange" },
              { "value": 80, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "title": "RTO per RestoreTest",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "kymaros_rto_seconds",
          "legendFormat": "{{ test }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50
          }
        }
      }
    },
    {
      "title": "Backup Age",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "kymaros_backup_age_seconds / 3600",
          "legendFormat": "{{ test }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 24, "color": "orange" },
              { "value": 48, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "title": "Test Duration Distribution",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "kymaros_test_duration_seconds_bucket",
          "legendFormat": "{{ test }}",
          "refId": "A",
          "format": "heatmap"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "title": "Tests by Result",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "sum by (result) (kymaros_tests_total)",
          "legendFormat": "{{ result }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "pass" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#10b981" } }]
          },
          {
            "matcher": { "id": "byName", "options": "fail" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#ef4444" } }]
          },
          {
            "matcher": { "id": "byName", "options": "partial" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#f59e0b" } }]
          }
        ]
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["kymaros", "kubernetes", "backup", "restore"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "",
  "title": "Kymaros — Backup Restore Validation",
  "uid": "kymaros-overview",
  "version": 1
}
